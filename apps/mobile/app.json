{
  "expo": {
    "name": "VendorApp",
    "slug": "vendorin",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.vendorin.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vendorin.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "expo-notifications",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Izinkan VendorIn menyimpan QR Code ke galeri Anda",
          "savePhotosPermission": "Izinkan VendorIn menyimpan QR Code ke galeri Anda"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/6d185c62-038d-49a2-9e24-9c9a81fdcb38",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "6d185c62-038d-49a2-9e24-9c9a81fdcb38"
      }
    },
    "owner": "vendorin"
  }
}
